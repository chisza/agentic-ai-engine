FROM python:3.14-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
COPY app/ ./app/

RUN pip install --no-cache-dir .

EXPOSE 8002

CMD ["uvicorn", "app.a2a_servers.critic.server:app", "--host", "0.0.0.0", "--port", "8002"]
